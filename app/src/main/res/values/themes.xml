<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Calculator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bg_btn_shift</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="android:navigationBarColor">@color/bg_main</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Default calculator function button -->
    <style name="CalcBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">2dp</item>
        <item name="android:layout_marginEnd">2dp</item>
        <item name="android:textColor">@color/txt_btn</item>
        <item name="android:textSize">13sp</item>
        <item name="android:backgroundTint">@color/bg_btn_default</item>
        <item name="android:paddingStart">2dp</item>
        <item name="android:paddingEnd">2dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:letterSpacing">0</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- Number pad button (slightly larger) -->
    <style name="NumBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">2dp</item>
        <item name="android:layout_marginEnd">2dp</item>
        <item name="android:textColor">@color/txt_btn</item>
        <item name="android:textSize">20sp</item>
        <item name="android:backgroundTint">@color/bg_btn_numpad</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- Orange accent (DEL / AC / =) -->
    <style name="AccentBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">2dp</item>
        <item name="android:layout_marginEnd">2dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">18sp</item>
        <item name="android:backgroundTint">@color/bg_btn_orange</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- Equals button -->
    <style name="EqualBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">2dp</item>
        <item name="android:layout_marginEnd">2dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">22sp</item>
        <item name="android:backgroundTint">#FFCC5500</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- Shift-label text above each button -->
    <style name="ShiftLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">14dp</item>
        <item name="android:textSize">8sp</item>
        <item name="android:textColor">@color/txt_shift_label</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:ellipsize">none</item>
        <item name="android:singleLine">true</item>
    </style>

    <!-- Section header in the function area -->
    <style name="SectionDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/divider</item>
        <item name="android:layout_marginVertical">4dp</item>
    </style>

</resources>
