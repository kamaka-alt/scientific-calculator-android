<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- ══════════════════════════════════════════
         TOP MODE BAR  —  NORM  MATH  DECI
         ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/modeBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="6dp"
        android:paddingBottom="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView android:id="@+id/tvNorm"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="NORM" android:textSize="11sp" android:fontFamily="monospace"
            android:textColor="@color/txt_mode_active" android:paddingEnd="14dp"/>
        <TextView android:id="@+id/tvMath"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="MATH" android:textSize="11sp" android:fontFamily="monospace"
            android:textColor="@color/txt_mode_inactive" android:paddingEnd="14dp"/>
        <TextView android:id="@+id/tvDeci"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DECI" android:textSize="11sp" android:fontFamily="monospace"
            android:textColor="@color/txt_mode_inactive"/>
    </LinearLayout>

    <!-- ══════════════════════════════════════════
         DISPLAY  —  aqua/mint card
         ══════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/displayCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="4dp"
        app:cardBackgroundColor="@color/bg_display"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/modeBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.24"
        app:layout_constraintBottom_toTopOf="@id/controlBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="bottom"
            android:padding="12dp">

            <!-- Expression line (scrolls right) -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:fillViewport="true">
                <TextView
                    android:id="@+id/tvExpression"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/txt_display_expr"
                    android:textSize="20sp"
                    android:fontFamily="monospace"
                    android:singleLine="true"
                    android:gravity="end|bottom"
                    android:hint="0"
                    android:textColorHint="#66333333"/>
            </HorizontalScrollView>

            <!-- Result line -->
            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/txt_display_result"
                android:textSize="30sp"
                android:fontFamily="monospace"
                android:gravity="end"
                android:singleLine="true"
                android:ellipsize="start"
                android:paddingTop="6dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ══════════════════════════════════════════
         CONTROL BAR  —  SHIFT  ALPHA  ◄  ►  DEG
         ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/controlBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="5dp"
        android:gravity="center_vertical"
        android:background="@color/bg_control"
        app:layout_constraintTop_toBottomOf="@id/displayCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShift"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="2"
            android:text="SHIFT" android:textSize="13sp" android:textColor="@color/white"
            android:backgroundTint="@color/bg_btn_shift" android:layout_marginEnd="4dp"
            app:cornerRadius="6dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAlpha"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="2"
            android:text="ALPHA" android:textSize="13sp" android:textColor="@color/white"
            android:backgroundTint="@color/bg_btn_alpha" android:layout_marginEnd="4dp"
            app:cornerRadius="6dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLeft"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1.4"
            android:text="◄" android:textSize="15sp" android:textColor="@color/white"
            android:backgroundTint="@color/bg_btn_default" android:layout_marginEnd="4dp"
            app:cornerRadius="6dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRight"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1.4"
            android:text="►" android:textSize="15sp" android:textColor="@color/white"
            android:backgroundTint="@color/bg_btn_default" android:layout_marginEnd="4dp"
            app:cornerRadius="6dp"/>

        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAngleMode"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1.6"
            android:text="DEG" android:textSize="11sp" android:textColor="@color/white"
            app:strokeColor="@color/divider" app:cornerRadius="6dp"/>
    </LinearLayout>

    <!-- ══════════════════════════════════════════
         NUMBER PAD  —  fixed at bottom
         ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/numPad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="6dp"
        android:paddingBottom="8dp"
        android:paddingTop="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row: 7  8  9  ⌫  AC -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="3dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btn7"   style="@style/NumBtn" android:text="7"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btn8"   style="@style/NumBtn" android:text="8"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btn9"   style="@style/NumBtn" android:text="9"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnDel" style="@style/AccentBtn" android:text="⌫" android:textSize="20sp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnAC"  style="@style/AccentBtn" android:text="AC"/>
        </LinearLayout>

        <!-- Row: 4  5  6  ×  ÷ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="3dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btn4"   style="@style/NumBtn" android:text="4"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btn5"   style="@style/NumBtn" android:text="5"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btn6"   style="@style/NumBtn" android:text="6"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnMul" style="@style/NumBtn" android:text="×"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnDiv" style="@style/NumBtn" android:text="÷"/>
        </LinearLayout>

        <!-- Row: 1  2  3  +  − -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="3dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btn1"   style="@style/NumBtn" android:text="1"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btn2"   style="@style/NumBtn" android:text="2"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btn3"   style="@style/NumBtn" android:text="3"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnAdd" style="@style/NumBtn" android:text="+"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnSub" style="@style/NumBtn" android:text="−"/>
        </LinearLayout>

        <!-- Row: 0  .  Exp  Ans  = -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton android:id="@+id/btn0"      style="@style/NumBtn" android:text="0"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnDot"    style="@style/NumBtn" android:text="." android:textSize="24sp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnExpN"   style="@style/NumBtn" android:text="Exp" android:textSize="14sp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnAns"    style="@style/NumBtn" android:text="Ans" android:textSize="14sp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnEquals" style="@style/EqualBtn" android:text="="/>
        </LinearLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════════
         SCROLLABLE FUNCTION AREA
         between control bar and number pad
         ══════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/funcScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="6dp"
        android:paddingTop="4dp"
        android:scrollbars="none"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/controlBar"
        app:layout_constraintBottom_toTopOf="@id/numPad"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── ROW 1: CALC  ∫dx  ▲  ▼  x⁻¹  Logₓy ───────────── -->
            <!-- Shift labels -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="2dp">
                <TextView style="@style/ShiftLabel" android:text="SOLVE="/>
                <TextView style="@style/ShiftLabel" android:text="d/dx"/>
                <TextView style="@style/ShiftLabel" android:text=""/>
                <TextView style="@style/ShiftLabel" android:text=""/>
                <TextView style="@style/ShiftLabel" android:text="x!"/>
                <TextView style="@style/ShiftLabel" android:text="Π"/>
            </LinearLayout>
            <!-- Main buttons -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="4dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnCalc"      style="@style/CalcBtn" android:text="CALC"   android:textSize="11sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnIntegral"  style="@style/CalcBtn" android:text="∫dx"    android:textSize="14sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnUp"        style="@style/CalcBtn" android:text="▲"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnDown"      style="@style/CalcBtn" android:text="▼"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnRecip"     style="@style/CalcBtn" android:text="x⁻¹"   android:textSize="12sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnLogXY"     style="@style/CalcBtn" android:text="Logₓy" android:textSize="11sp"/>
            </LinearLayout>

            <!-- ── ROW 2: x/y  √x  x²  xʸ  Log  Ln ────────────────── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView style="@style/ShiftLabel" android:text="÷R"/>
                <TextView style="@style/ShiftLabel" android:text="∛x"/>
                <TextView style="@style/ShiftLabel" android:text="x³"/>
                <TextView style="@style/ShiftLabel" android:text="x^(1/y)"/>
                <TextView style="@style/ShiftLabel" android:text="10ˣ"/>
                <TextView style="@style/ShiftLabel" android:text="eˣ"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="4dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnFrac"   style="@style/CalcBtn" android:text="x/y"  android:textSize="12sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnSqrt"  style="@style/CalcBtn" android:text="√x"   android:textSize="14sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnSq"    style="@style/CalcBtn" android:text="x²"   android:textSize="13sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnPow"   style="@style/CalcBtn" android:text="xʸ"   android:textSize="13sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnLog"   style="@style/CalcBtn" android:text="Log"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnLn"    style="@style/CalcBtn" android:text="Ln"/>
            </LinearLayout>

            <!-- ── ROW 3: (−)  °'"  hyp  Sin  Cos  Tan ─────────────── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView style="@style/ShiftLabel" android:text=""/>
                <TextView style="@style/ShiftLabel" android:text="FACT"/>
                <TextView style="@style/ShiftLabel" android:text="|x|"/>
                <TextView style="@style/ShiftLabel" android:text="Sin⁻¹"/>
                <TextView style="@style/ShiftLabel" android:text="Cos⁻¹"/>
                <TextView style="@style/ShiftLabel" android:text="Tan⁻¹"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="4dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnNeg"  style="@style/CalcBtn" android:text="(−)"  android:textSize="12sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnDMS"  style="@style/CalcBtn" android:text="°'\""  android:textSize="12sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnHyp"  style="@style/CalcBtn" android:text="hyp"  android:textSize="12sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnSin"  style="@style/CalcBtn" android:text="Sin"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnCos"  style="@style/CalcBtn" android:text="Cos"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnTan"  style="@style/CalcBtn" android:text="Tan"/>
            </LinearLayout>

            <!-- ── ROW 4: RCL  ENG  (  )  S⇔D  M+ ─────────────────── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView style="@style/ShiftLabel" android:text="STO"/>
                <TextView style="@style/ShiftLabel" android:text="i"/>
                <TextView style="@style/ShiftLabel" android:text="%"/>
                <TextView style="@style/ShiftLabel" android:text="Cot"/>
                <TextView style="@style/ShiftLabel" android:text="M−"/>
                <TextView style="@style/ShiftLabel" android:text="CLR"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnRCL"   style="@style/CalcBtn" android:text="RCL"  android:textSize="12sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnENG"   style="@style/CalcBtn" android:text="ENG"  android:textSize="12sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnOpen"  style="@style/CalcBtn" android:text="("/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnClose" style="@style/CalcBtn" android:text=")"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnStoD"  style="@style/CalcBtn" android:text="S⇔D"  android:textSize="11sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMPlus" style="@style/CalcBtn" android:text="M+"   android:textSize="12sp"/>
            </LinearLayout>

            <!-- ── DIVIDER ──────────────────────────────────────────── -->
            <View style="@style/SectionDivider"/>

            <!-- ── ROW 5: MATRIX  VECTOR  STAT  CMPLX  BaseN  CONST ── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="4dp"
                android:layout_marginTop="2dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMatrix"  style="@style/CalcBtn" android:text="MATRIX"  android:textSize="10sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnVector"  style="@style/CalcBtn" android:text="VECTOR"  android:textSize="10sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnStat"    style="@style/CalcBtn" android:text="STAT"    android:textSize="10sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnCmplx"   style="@style/CalcBtn" android:text="CMPLX"   android:textSize="10sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnBaseN"   style="@style/CalcBtn" android:text="BaseN"   android:textSize="10sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnConst"   style="@style/CalcBtn" android:text="CONST"   android:textSize="10sp"/>
            </LinearLayout>

            <!-- ── ROW 6: nCr  nPr  Pol(  Rec(  rand  CONV ────────── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="4dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnNCr"     style="@style/CalcBtn" android:text="nCr"     android:textSize="12sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnNPr"     style="@style/CalcBtn" android:text="nPr"     android:textSize="12sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnPol"     style="@style/CalcBtn" android:text="Pol("    android:textSize="12sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnRec"     style="@style/CalcBtn" android:text="Rec("    android:textSize="12sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnRand"    style="@style/CalcBtn" android:text="Ran#"    android:textSize="11sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnConv"    style="@style/CalcBtn" android:text="CONV"    android:textSize="10sp"/>
            </LinearLayout>

            <!-- ── ROW 7: solve(  ∫(  d/dx(  stat1:  stat2:  GCD ──── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnSolve"   style="@style/CalcBtn" android:text="solve(" android:textSize="10sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnIntExpr" style="@style/CalcBtn" android:text="∫("     android:textSize="13sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnDiff"    style="@style/CalcBtn" android:text="d/dx("  android:textSize="10sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnStat1"   style="@style/CalcBtn" android:text="stat1:" android:textSize="10sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnStat2"   style="@style/CalcBtn" android:text="stat2:" android:textSize="10sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnGCD"     style="@style/CalcBtn" android:text="gcd("   android:textSize="11sp"/>
            </LinearLayout>

            <!-- ── ROW 8: History  π  e  PreAns  abs(  det( ─────────── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="4dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnHistory" style="@style/CalcBtn" android:text="Hist"  android:textSize="11sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnPi"      style="@style/CalcBtn" android:text="π"     android:textSize="18sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnE"       style="@style/CalcBtn" android:text="e"     android:textSize="17sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnAbs"     style="@style/CalcBtn" android:text="abs("  android:textSize="11sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnDet"     style="@style/CalcBtn" android:text="det("  android:textSize="11sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnTrans"   style="@style/CalcBtn" android:text="trans(" android:textSize="9sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
